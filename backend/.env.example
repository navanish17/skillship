# File:    backend/.env.example
# Purpose: Template of environment variables every dev must fill locally (copy to .env).
# Why:     Never commit real secrets; .env is in .gitignore. This file is the "menu".
# Owner:   Navanish

# --- Django ---
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_ALLOWED_HOSTS=*

# --- Database ---
DATABASE_URL=postgres://skillship:skillship@localhost:5432/skillship

# --- Redis / Celery ---
REDIS_URL=redis://localhost:6379/0

# --- AI service ---
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_INTERNAL_KEY=change-me-shared-with-ai-service

# --- Email (dev: console) ---
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# --- Object storage (S3 / DigitalOcean Spaces) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=

# --- Sentry (prod only) ---
SENTRY_DSN=
