# File:    frontend/.env.example
# Purpose: Template env vars for the Next.js frontend.
# Owner:   Pranav
# Copy to .env.local and fill in values before running `npm run dev`.

# Django DRF backend base — must include /api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Application display name
NEXT_PUBLIC_APP_NAME=Skillship
