# File:    ai-service/.env.example
# Purpose: Template env vars for the AI service.
# Owner:   Navanish

ANTHROPIC_API_KEY=sk-ant-...
MODEL_NAME=claude-opus-4-6
EMBEDDING_MODEL=voyage-3

# Shared with backend — Django sends this in X-Internal-Key header
AI_SERVICE_INTERNAL_KEY=change-me-shared-with-backend

# Same Postgres as backend (we read/write pgvector table here)
PGVECTOR_URL=postgres://skillship:skillship@localhost:5432/skillship

LOG_LEVEL=INFO
