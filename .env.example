# File:    .env.example (root)
# Purpose: A single-file snapshot of every env var used across all services.
# Why:     New teammates see the full picture in one place; each service also has its own copy.
# Owner:   Navanish

# ===== Backend (Django) =====
DJANGO_SECRET_KEY=change-me
DJANGO_SETTINGS_MODULE=config.settings.dev
DATABASE_URL=postgres://skillship:skillship@localhost:5432/skillship
REDIS_URL=redis://localhost:6379/0
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_INTERNAL_KEY=change-me-shared-secret
SENTRY_DSN=

# ===== AI service (FastAPI) =====
ANTHROPIC_API_KEY=sk-ant-...
MODEL_NAME=claude-opus-4-6
EMBEDDING_MODEL=voyage-3
PGVECTOR_URL=postgres://skillship:skillship@localhost:5432/skillship

# ===== Frontend (Next.js) =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Skillship

# ===== Infra (docker-compose) =====
POSTGRES_DB=skillship
POSTGRES_USER=skillship
POSTGRES_PASSWORD=change-me
